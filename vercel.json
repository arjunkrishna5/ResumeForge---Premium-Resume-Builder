{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/gemini",
      "destination": "/api/gemini"
    },
    {
      "source": "/api/extractText", 
      "destination": "/api/extractText"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
